# Get a free key at https://sam.gov → sign in → Account Details → Public API Key
SAM_GOV_API_KEY=your_key_here

NAICS_CODES=561720,561210,561730,561710,561790,561612
MIN_DAYS_UNTIL_DUE=10
MIN_SCORE_THRESHOLD=1

# PostgreSQL — use DATABASE_PUBLIC_URL from Railway (for local dev on your PC)
DATABASE_URL=your_railway_postgres_url_here

# Anthropic API — for Claude contract screening (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Login — email and password (required for Railway / public access)
APP_EMAIL=you@example.com
APP_PASSWORD=choose_a_strong_password
SECRET_KEY=random_long_secret_for_session_cookies

# Daily auto-sync (runs when the app is up via uvicorn/Railway)
SCHEDULER_ENABLED=true
DAILY_REFRESH_HOUR=6
DAILY_REFRESH_MINUTE=0
SCHEDULER_TIMEZONE=America/Denver

# API budgets — SAM.gov capped daily (10 for personal keys, set 900+ when raised to 1000/day)
PIEE_FETCH_ENABLED=true
INTAKE_ON_SYNC=true
INTAKE_PER_SYNC_LIMIT=5
SAM_DAILY_API_BUDGET=10
SAM_PDF_DOWNLOAD_BUDGET=10
ANTHROPIC_DAILY_SCREEN_BUDGET=0
FULL_ANALYSIS_MIN_SCORE=6
ENRICH_ON_SYNC_LIMIT=5
AUTO_SCREEN_ON_STARTUP=false

# Google Places API (New) — enable Places API (New) in Google Cloud Console
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Sub Finder defaults (overridable in Settings UI)
SUB_SEARCH_RADIUS_MILES=25
SUB_MIN_RATING=3.5
SUB_MIN_REVIEW_COUNT=5

# Pricing comparables — stay local (same state, max distance in miles)
PRICING_MAX_DISTANCE_MILES=120
PRICING_ALLOW_NEIGHBOR_STATES=false
