# Get a free key at https://sam.gov → sign in → Account Details → Public API Key
SAM_GOV_API_KEY=your_key_here

# Fallback NAICS list if none saved in Settings (19 codes across 3 tiers)
NAICS_CODES=561720,561210,561730,561710,562111,561790,561740,562119,561439,541930,811192,238220,562910,484210,484110,492110,711320,532490,561422
MIN_DAYS_UNTIL_DUE=10
MIN_SCORE_THRESHOLD=1

# PostgreSQL — use DATABASE_PUBLIC_URL from Railway (for local dev on your PC)
DATABASE_URL=your_railway_postgres_url_here

# Anthropic API — for Claude contract screening (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Login — email and password (required for Railway / public access)
APP_EMAIL=you@example.com
APP_PASSWORD=your_password_here
SECRET_KEY=generate_a_long_random_string

# Daily auto-sync at 6am (America/Denver) — tiered: T1 daily, T2 Mon/Wed/Fri, T3 Sunday
SCHEDULER_ENABLED=true
DAILY_REFRESH_HOUR=6
DAILY_REFRESH_MINUTE=0
SCHEDULER_TIMEZONE=America/Denver

# Google Places API (New) — for Sub Finder
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# API budgets — only SAM_DAILY_API_BUDGET gates work (search + attachment metadata API calls).
# PDF file downloads and Claude are not capped by this app.
SAM_DAILY_API_BUDGET=10
SCHEDULED_NAICS_PER_SYNC=1
SAM_PDF_DOWNLOAD_BUDGET=0
ANTHROPIC_DAILY_SCREEN_BUDGET=0
INTAKE_ON_SYNC=true
INTAKE_PER_SYNC_LIMIT=2
FULL_ANALYSIS_MIN_SCORE=6
ATTACHMENT_ENRICH_PER_SYNC_LIMIT=0
